  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "npx kill-port 5180 && npx kill-port 5001 && refine dev",
    "dev:server": "npx kill-port 3007 && nodemon --watch server --ignore server/dist --ext ts,json --exec \"tsx server/src/index.ts\"",
    "build": "tsc && refine build && npm run build:server",
    "build:server": "tsc -p server/tsconfig.json",
    "start:server": "node server/dist/index.js",
    "preview": "refine start",
    "refine": "refine",
    "codegen": "graphql-codegen"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "refine": {
    "projectId": "WVyLEd-4karEq-tItoeC"
  }
